<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"> <!-- off white-->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/nav_container"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal"
            android:clipToPadding="false"
            android:clipChildren="false">

            <!-- header section -->
            <ImageView
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginTop="24dp"
                android:src="@drawable/bbicon" />

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/ginto_nord_black"
                android:text="Good day, Jed."
                android:textColor="#333333"
                android:textSize="22sp" />

            <!-- baon -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_hero_balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#00B58B"
                app:cardCornerRadius="32dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/avenir_roman"
                        android:text="Remaining Baon"
                        android:textColor="#CCFFFFFF"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/tv_balance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/ginto_nord_black"
                        android:text="₱250"
                        android:textColor="#FFFFFF"
                        android:textSize="56sp"
                        android:maxLines="1"
                        app:autoSizeTextType="uniform"
                        app:autoSizeMinTextSize="32sp"
                        app:autoSizeMaxTextSize="64sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Savings Progress Tracker -->
            <LinearLayout
                android:id="@+id/container_savings_progress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical"
                android:paddingHorizontal="8dp"
                android:visibility="gone">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:fontFamily="@font/avenir_roman"
                        android:text="Savings Goal Progress"
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_savings_percent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/ginto_nord_black"
                        android:text="25%"
                        android:textColor="#00B58B"
                        android:textSize="12sp" />
                </RelativeLayout>

                <ProgressBar
                    android:id="@+id/pb_savings"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:progress="25"
                    android:max="100"
                    android:progressDrawable="@drawable/rounded_bg2"
                    android:background="@drawable/rounded_bg"
                    android:backgroundTint="#EEEEEE" />

                <TextView
                    android:id="@+id/tv_savings_remaining"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="@font/avenir_roman"
                    android:text="₱750 more to reach your ₱1,000 goal"
                    android:textAlignment="center"
                    android:textColor="#AAAAAA"
                    android:textSize="11sp" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:orientation="vertical"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="@font/avenir_roman"
                    android:text="RECENT ACTIVITY"
                    android:textAlignment="center"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:letterSpacing="0.1"
                    android:textStyle="bold" />


                <LinearLayout
                    android:id="@+id/group_recent_transactions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bordered_group_bg"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <RelativeLayout
                        android:id="@+id/card_recent_1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_recent_name_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Food"
                            android:fontFamily="@font/ginto_nord_black"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <TextView
                            android:id="@+id/tv_recent_amount_1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="-₱125"
                            android:fontFamily="@font/ginto_nord_black"
                            android:textSize="14sp"
                            android:textColor="#E53935" />
                    </RelativeLayout>

                    <!-- divider -->
                    <View
                        android:id="@+id/inner_divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F0F0F0"
                        android:layout_marginHorizontal="16dp"
                        android:visibility="gone" />

                    <RelativeLayout
                        android:id="@+id/card_recent_2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tv_recent_name_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:text="Transpo"
                            android:fontFamily="@font/ginto_nord_black"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <TextView
                            android:id="@+id/tv_recent_amount_2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="-₱20"
                            android:fontFamily="@font/ginto_nord_black"
                            android:textSize="14sp"
                            android:textColor="#E53935" />
                    </RelativeLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_no_recent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No activity yet"
                    android:fontFamily="@font/avenir_roman"
                    android:textSize="16sp"
                    android:textColor="#CCCCCC"
                    android:textAlignment="center"
                    android:layout_marginTop="24dp"
                    android:visibility="visible" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- navbar -->
    <LinearLayout
        android:id="@+id/nav_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:clipToPadding="false"
        android:background="@android:color/transparent"> <!-- Allow parent tint to show slightly or keep clean -->

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_marginEnd="12dp"
            android:background="@drawable/rounded_bg"
            android:backgroundTint="#FFFFFF"
            android:elevation="8dp"
            app:itemIconTint="#00B58B"
            app:itemTextColor="#00B58B"
            app:labelVisibilityMode="labeled"
            app:itemRippleColor="#2000B58B"
            app:menu="@menu/bottom_nav_menu" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_add"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/ic_input_add"
            android:elevation="8dp"
            app:backgroundTint="#00B58B"
            app:tint="#FFFFFF"
            app:fabCustomSize="56dp" />

    </LinearLayout>

</RelativeLayout>
