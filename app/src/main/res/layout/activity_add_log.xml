<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogExpense"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#FFFFFF"
            android:fontFamily="@font/ginto_nord_black"
            android:text="Log an\nExpense"
            android:textAllCaps="false"
            android:textColor="#00B58B"
            android:textSize="48sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLogBaon"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#00B58B"
            android:fontFamily="@font/ginto_nord_black"
            android:text="Log a\nBaon"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="24dp"
        android:background="@drawable/circle_bg"
        android:backgroundTint="#00B58B"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#FFFFFF"
        android:elevation="4dp" />

</RelativeLayout>