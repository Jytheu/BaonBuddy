<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp">
    <!-- back button-->
    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/circle_bg"
        android:backgroundTint="#00B58B"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#FFFFFF" />

    <ImageView
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:src="@drawable/bblack"
        android:adjustViewBounds="true"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create an account"
        android:fontFamily="@font/ginto_nord_black"
        android:textSize="20sp"
        android:textColor="#000000"
        android:textAlignment="center"
        android:layout_marginTop="24dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:fontFamily="@font/avenir_roman"
        android:text="Enter your details to sign up for BaonBuddy"
        android:textAlignment="center"
        android:textColor="#666666"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/et_name"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Name"
        android:fontFamily="@font/avenir_roman"
        android:background="@drawable/rounded_bg"
        android:elevation="2dp"
        android:paddingStart="16dp"
        android:layout_marginBottom="16dp"
        android:textColor="#000000"/>

    <EditText
        android:id="@+id/et_email"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="email@domain.com"
        android:fontFamily="@font/avenir_roman"
        android:background="@drawable/rounded_bg"
        android:elevation="2dp"
        android:paddingStart="16dp"
        android:layout_marginBottom="16dp"
        android:textColor="#000000"/>

    <EditText
        android:id="@+id/et_password"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Password"
        android:fontFamily="@font/avenir_roman"
        android:inputType="textPassword"
        android:background="@drawable/rounded_bg"
        android:elevation="2dp"
        android:paddingStart="16dp"
        android:layout_marginBottom="32dp"
        android:textColor="#000000"/>

    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@drawable/rounded_bg2"
        app:backgroundTint="@null"
        android:fontFamily="@font/ginto_nord_black"
        android:text="Create your account"
        android:textAllCaps="false"
        android:textColor="#FFFFFF" />

</LinearLayout>