<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/btn_back"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/circle_bg"
        android:backgroundTint="#00B58B"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_revert"
        app:tint="#FFFFFF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/ginto_nord_black"
        android:text="Select Category"
        android:textAlignment="center"
        android:textColor="#333333"
        android:textSize="28sp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:fontFamily="@font/avenir_roman"
        android:text="Where did your money go?"
        android:textAlignment="center"
        android:textColor="#888888"
        android:textSize="16sp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="2">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnFood"
            style="@style/CategoryButton"
            android:text="Food" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTranspo"
            style="@style/CategoryButton"
            android:text="Transpo" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnAcads"
            style="@style/CategoryButton"
            android:text="Acads" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnOthers"
            style="@style/CategoryButton"
            android:text="Others" />

    </GridLayout>

    <EditText
        android:id="@+id/etCustomCategory"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/rounded_bg"
        android:backgroundTint="#F5F5F5"
        android:elevation="0dp"
        android:fontFamily="@font/avenir_roman"
        android:hint="Or enter custom label..."
        android:paddingStart="16dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/rounded_bg2"
        app:backgroundTint="@null"
        android:fontFamily="@font/ginto_nord_black"
        android:text="Next"
        android:textAllCaps="false"
        android:textColor="#FFFFFF" />

</LinearLayout>